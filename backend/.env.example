# LLM BYOK 配置（OpenAI 兼容格式）
# 支持 OpenAI / StepFun / DeepSeek / OpenRouter 等所有 OpenAI Chat Completions 兼容接口
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_CONTEXT_WINDOW=128000

# LLM 嵌入（可选）：用于 RAG 索引构建与检索。
# 三个字段任一未设置时会自动回退到上方的 LLM_API_BASE / LLM_API_KEY / LLM_MODEL,
# 因此常规用户无需填写。常见用法：把 embeddings 指向专门的 bge 等模型服务，
# 比如 SiliconFlow：LLM_EMBEDDINGS_BASE=https://api.siliconflow.cn/v1
#                   LLM_EMBEDDINGS_MODEL=BAAI/bge-m3
# 注意：StepFun 平台无 /embeddings 端点,不能用作 embeddings base。
# LLM_EMBEDDINGS_BASE=
# LLM_EMBEDDINGS_KEY=
# LLM_EMBEDDINGS_MODEL=

# 企业知识库 RAG 后端选择（默认 local，无需改动即可使用现有 Chroma + /embeddings）
# - local:本地 Chroma + 调用 LLM 提供商的 /embeddings（适用 OpenAI / DeepSeek / SiliconFlow / GLM / Moonshot 等）
# - stepfun:StepFun 托管 vector_stores。检索通过 tools[].type=retrieval 在 chat 时由 StepFun 服务端完成。
#           首次启动会自动创建 vector_store 并写入 STEPFUN_VECTOR_STORE_ID。
# - none:关闭企业知识库检索。
RAG_BACKEND=local
# 仅当 RAG_BACKEND=stepfun 时生效：复用已有的 vector_store ID，留空则自动创建。
# STEPFUN_VECTOR_STORE_ID=

# 服务配置
DATABASE_URL=sqlite:///./data/interviewos.db
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:3000
HOST=0.0.0.0
PORT=8000

# 语音配置（可选，未设置时使用默认值）
# Whisper 模型大小：tiny / base / small / medium / large-v3
WHISPER_MODEL=base
# Edge TTS 语音 ID，默认中文女声
TTS_VOICE=zh-CN-XiaoxiaoNeural
# 用户停顿后触发"请问还在吗"提示的秒数
SILENCE_NUDGE_SECONDS=10
