# LLM BYOK 配置（OpenAI 兼容格式）
# 支持 OpenAI / StepFun / DeepSeek / OpenRouter 等所有 OpenAI Chat Completions 兼容接口
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_CONTEXT_WINDOW=128000

# 服务配置
DATABASE_URL=sqlite:///./data/interviewos.db
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:3000
HOST=0.0.0.0
PORT=8000

# 语音配置（可选，未设置时使用默认值）
# Whisper 模型大小：tiny / base / small / medium / large-v3
WHISPER_MODEL=base
# Edge TTS 语音 ID，默认中文女声
TTS_VOICE=zh-CN-XiaoxiaoNeural
# 用户停顿后触发"请问还在吗"提示的秒数
SILENCE_NUDGE_SECONDS=10
